<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.xiaokui.mapper.ClassMapper">
    <select id="createClass">
        select create_class(#{name}, #{teacherId});
    </select>

    <select id="pageLimit" resultType="com.xiaokui.dto.ClassTable">
        select *
        from page_class(#{start}, #{size});
    </select>

    <select id="delClass">
        select del_class(#{id})
    </select>

    <select id="updateClass">
        select update_class(#{name}, #{id}, #{teacherId});
    </select>

    <select id="queryClass" resultType="com.xiaokui.dto.ClassTable">
        select *
        from query_class(#{id,jdbcType=INTEGER}, #{name,jdbcType=VARCHAR});
    </select>

    <select id="getMyAllStudent" resultType="com.xiaokui.dto.StudentOnlyIdName">
        select *
        from all_student(#{id});
    </select>

    <select id="getClassSum" resultType="java.lang.Integer">
        select count(*)
        from class c
        where c.is_delete = false;
    </select>

</mapper>