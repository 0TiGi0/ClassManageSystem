<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.xiaokui.mapper.StudentMapper">
    <select id="pageLimit" resultType="com.xiaokui.dto.StudentTable">
        select *
        from page_student(#{start,jdbcType=INTEGER}, #{size,jdbcType=INTEGER});
    </select>

    <select id="createStudent">
        select create_student(#{name,jdbcType=VARCHAR}, #{age,jdbcType=INTEGER}, #{gender,jdbcType=VARCHAR},
                              #{classId,jdbcType=INTEGER});
    </select>

    <select id="delStudent">
        select del_student(#{id,jdbcType=INTEGER});
    </select>

    <select id="updateStudent">
        select update_student(#{id,jdbcType=INTEGER}, #{name,jdbcType=VARCHAR}, #{age,jdbcType=INTEGER},
                              #{gender,jdbcType=VARCHAR}, #{classId,jdbcType=INTEGER});
    </select>

    <select id="queryStudent" resultType="com.xiaokui.dto.StudentTable">
        select *
        from query_student(#{id,jdbcType=INTEGER}, #{name,jdbcType=VARCHAR}, #{teacherName,jdbcType=VARCHAR},
                           #{className,jdbcType=VARCHAR});
    </select>

    <select id="getStudentSum" resultType="java.lang.Integer">
        select count(*)
        from student s
        where s.is_delete = false;
    </select>
</mapper>